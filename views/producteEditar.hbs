<h1>✏️ Editar producte</h1>

<div class="card">
  <form method="POST" action="/update" onsubmit="validaProducte(event)">
    <input type="hidden" name="table" value="products">
    <input type="hidden" name="id" value="{{producte.id}}">

    <div class="form-grid">
      <div class="form-group">
        <label for="name">Nom *</label>
        <input type="text" id="name" name="name" value="{{producte.name}}">
        <span class="missatge-error"></span>
      </div>

      <div class="form-group">
        <label for="category">Categoria *</label>
        <input type="text" id="category" name="category" value="{{producte.category}}">
        <span class="missatge-error"></span>
      </div>

      <div class="form-group">
        <label for="price">Preu (€) *</label>
        <input type="number" id="price" name="price" step="0.01" min="0" value="{{producte.price}}">
        <span class="missatge-error"></span>
      </div>

      <div class="form-group">
        <label for="stock">Stock *</label>
        <input type="number" id="stock" name="stock" min="0" step="1" value="{{producte.stock}}">
        <span class="missatge-error"></span>
      </div>

      <div class="form-group">
        <label for="active">Actiu</label>
        <select id="active" name="active">
          <option value="1" {{#if producte.active}}selected{{/if}}>Sí</option>
          <option value="" {{#unless producte.active}}selected{{/unless}}>No</option>
        </select>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Guardar canvis</button>
      <a href="/productes" class="btn btn-secondary">Cancel·lar</a>
    </div>
  </form>
</div>

<!-- Esborrar -->
<div class="card" style="border-color:var(--danger);">
  <h2 style="color:var(--danger);">⚠️ Zona de perill</h2>
  <p style="margin:0.5rem 0 1rem; color:var(--text-muted); font-size:0.9rem;">Aquesta acció no es pot desfer.</p>
  <form method="POST" action="/delete" onsubmit="return confirm('Segur que vols esborrar aquest producte?')">
    <input type="hidden" name="table" value="products">
    <input type="hidden" name="id" value="{{producte.id}}">
    <input type="hidden" name="redirect" value="/productes">
    <button type="submit" class="btn btn-danger">🗑 Esborrar producte</button>
  </form>
</div>
