<div class="page-header">
  <h1>👤 {{client.name}}</h1>
  <div>
    <a href="/clientEditar?id={{client.id}}" class="btn-secondary">✏️ Editar</a>
    <a href="/clients" class="btn-secondary">← Tornar</a>
  </div>
</div>

<div class="grid-2">
  <div class="card">
    <h2>Dades del client</h2>
    <p><strong>Email:</strong> {{client.email}}</p>
    <p><strong>Telèfon:</strong> {{client.phone}}</p>
    <p><strong>Registrat:</strong> {{formatDate client.created_at}}</p>
  </div>
  <div class="card">
    <h2>Resum econòmic</h2>
    <p><strong>Total gastat:</strong> {{gastat}} €</p>
    <p><strong>Ticket mitjà:</strong> {{ticketMitja}} €</p>
  </div>
</div>

<div class="card">
  <h2>🛒 Últimes 10 compres</h2>
  {{#if vendes.length}}
  <table class="taula">
    <thead>
      <tr><th>#</th><th>Data</th><th>Mètode pagament</th><th>Total</th></tr>
    </thead>
    <tbody>
      {{#each vendes}}
      <tr>
        <td><a href="/vendaDetall?id={{id}}">#{{id}}</a></td>
        <td>{{formatDate sale_date}}</td>
        <td>{{payment_method}}</td>
        <td>{{toFixed2 total}} €</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
    <p>Aquest client no ha realitzat cap compra.</p>
  {{/if}}
</div>
