<div class="page-header">
  <h1>{{title}}</h1>
  <a href="/clients" class="btn-secondary">← Tornar</a>
</div>

<div class="card form-card">
  <form id="formClient" method="POST" action="/{{accio}}" novalidate>
    <input type="hidden" name="taula" value="clients" />
    {{#if client}}<input type="hidden" name="id" value="{{client.id}}" />{{/if}}

    <div class="form-group">
      <label for="name">Nom *</label>
      <input type="text" id="name" name="name" value="{{client.name}}" />
      <span class="error-msg" id="err-name"></span>
    </div>

    <div class="form-group">
      <label for="email">Email *</label>
      <input type="email" id="email" name="email" value="{{client.email}}" />
      <span class="error-msg" id="err-email"></span>
    </div>

    <div class="form-group">
      <label for="phone">Telèfon *</label>
      <input type="text" id="phone" name="phone" value="{{client.phone}}" />
      <span class="error-msg" id="err-phone"></span>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary">💾 Guardar</button>
      {{#if client}}
        <form method="POST" action="/Delete" style="display:inline" onsubmit="return confirm('Segur que vols esborrar aquest client?')">
          <input type="hidden" name="taula" value="clients" />
          <input type="hidden" name="id" value="{{client.id}}" />
          <button type="submit" class="btn-danger">🗑️ Esborrar</button>
        </form>
      {{/if}}
    </div>
  </form>
</div>

<script>
document.getElementById('formClient').addEventListener('submit', function(e) {
  let valid = true;

  const name = document.getElementById('name');
  const errName = document.getElementById('err-name');
  if (name.value.trim().length < 2) {
    errName.textContent = 'El nom és obligatori (mínim 2 caràcters)';
    name.classList.add('input-error');
    valid = false;
  } else {
    errName.textContent = '';
    name.classList.remove('input-error');
  }

  const email = document.getElementById('email');
  const errEmail = document.getElementById('err-email');
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email.value.trim())) {
    errEmail.textContent = 'Introdueix un email vàlid';
    email.classList.add('input-error');
    valid = false;
  } else {
    errEmail.textContent = '';
    email.classList.remove('input-error');
  }

  const phone = document.getElementById('phone');
  const errPhone = document.getElementById('err-phone');
  if (phone.value.trim().length < 9) {
    errPhone.textContent = 'El telèfon ha de tenir mínim 9 dígits';
    phone.classList.add('input-error');
    valid = false;
  } else {
    errPhone.textContent = '';
    phone.classList.remove('input-error');
  }

  if (!valid) e.preventDefault();
});
</script>
