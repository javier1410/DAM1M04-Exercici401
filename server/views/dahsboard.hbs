<h2>Dashboard</h2>

<div class="card">
  <h3>KPI</h3>
  <button onclick="toggleCompacte('panellKPI')">Tauler compacte / complet</button>

  <div id="panellKPI">
    <p><strong>Vendes d'avui:</strong> {{vendesAvui}}</p>
    <p><strong>Comandes d'avui:</strong> {{comandesAvui}}</p>

    <div class="extra">
      <p><strong>Vendes del mes:</strong> {{vendesMes}}</p>
      <p><strong>Comandes del mes:</strong> {{comandesMes}}</p>
      <p><strong>Productes amb stock baix:</strong> {{stockBaix}}</p>
    </div>
  </div>
</div>

<div class="card">
  <h3>Llistats</h3>
  <button onclick="toggleColorsStock()">Activar / desactivar colors stock</button>

  <h4>Últimes 5 vendes</h4>
  <table>
    <tr>
      <th>Data</th>
      <th>Client</th>
      <th>Total</th>
    </tr>
    {{#each ultimesVendes}}
      <tr>
        <td>{{this.sale_date}}</td>
        <td>{{this.client}}</td>
        <td>{{this.total}}</td>
      </tr>
    {{/each}}
  </table>

  <h4>Top 5 productes més venuts</h4>
  <table>
    <tr>
      <th>Producte</th>
      <th>Unitats</th>
    </tr>
    {{#each topProductes}}
      <tr>
        <td>{{this.name}}</td>
        <td>{{this.unitats}}</td>
      </tr>
    {{/each}}
  </table>
</div>