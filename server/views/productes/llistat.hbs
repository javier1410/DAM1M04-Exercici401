<h2>Productes</h2>

<form method="GET" action="/productes">
  <input type="text" name="cerca" value="{{cerca}}" placeholder="Buscar per nom o categoria">
  <input type="hidden" name="pagina" value="0">
  <button type="submit">Cercar</button>
</form>

<p>
  <a class="boto" href="/producteAfegir">Afegir producte</a>
  <button type="button" onclick="toggleColorsStock()">Colors stock on/off</button>
</p>

<table>
  <tr>
    <th>Nom</th>
    <th>Categoria</th>
    <th>Preu</th>
    <th>Stock</th>
    <th>Actiu</th>
    <th>Accions</th>
  </tr>

  {{#each productes}}
    <tr class="{{this.stockClass}}">
      <td>{{this.name}}</td>
      <td>{{this.category}}</td>
      <td>{{this.price}}</td>
      <td>{{this.stock}}</td>
      <td>{{this.active}}</td>
      <td><a href="/producteEditar?id={{this.id}}">Editar</a></td>
    </tr>
  {{/each}}
</table>

<div style="margin-top:15px;">
  {{#if paginaAnterior}}
    <a href="/productes?pagina={{paginaAnterior}}&cerca={{cerca}}">Anterior</a>
  {{/if}}

  <span>Pàgina {{pagina}}</span>

  {{#if paginaSeguent}}
    <a href="/productes?pagina={{paginaSeguent}}&cerca={{cerca}}">Següent</a>
  {{/if}}
</div>