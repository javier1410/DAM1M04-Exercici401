<div class="page-header">
  <h1>📦 Productes</h1>
  <a href="/producteAfegir" class="btn-primary">+ Afegir producte</a>
</div>

<!-- Buscador -->
<form class="search-bar" method="GET" action="/productes">
  <input type="text" name="cerca" value="{{cerca}}" placeholder="Buscar per nom o categoria..." />
  <button type="submit">🔍 Buscar</button>
  {{#if cerca}}<a href="/productes" class="btn-secondary">✖ Netejar</a>{{/if}}
</form>

<div class="tab-actions">
  <button class="btn-toggle" id="btnColors" onclick="toggleColors()">🎨 Colors stock</button>
</div>

<table class="taula" id="taulaProductes">
  <thead>
    <tr>
      <th>Nom</th><th>Categoria</th><th>Preu</th><th>Stock</th><th>Actiu</th><th>Accions</th>
    </tr>
  </thead>
  <tbody>
    {{#each productes}}
    <tr>
      <td>{{name}}</td>
      <td>{{category}}</td>
      <td>{{toFixed2 price}} €</td>
      <td class="stock-cell" data-stock="{{stock}}">{{stock}}</td>
      <td>{{#if active}}✅{{else}}❌{{/if}}</td>
      <td>
        <a href="/producteEditar?id={{id}}" class="btn-sm">✏️ Editar</a>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>

<!-- Paginació -->
<div class="paginacio">
  {{#if paginaAnterior }}
    {{#if (gt pagina 0)}}
      <a href="/productes?pagina={{paginaAnterior}}&cerca={{cerca}}" class="btn-secondary">← Anterior</a>
    {{/if}}
  {{/if}}
  <span>Pàgina {{add pagina 1}} de {{totalPagines}}</span>
  {{#if paginaSeguent}}
    <a href="/productes?pagina={{paginaSeguent}}&cerca={{cerca}}" class="btn-secondary">Següent →</a>
  {{/if}}
</div>

<script>
let colorsActius = false;
function toggleColors() {
  colorsActius = !colorsActius;
  const btn = document.getElementById('btnColors');
  btn.textContent = colorsActius ? '🎨 Desactiva colors' : '🎨 Colors stock';
  document.querySelectorAll('.stock-cell').forEach(td => {
    const v = parseInt(td.dataset.stock);
    if (colorsActius) {
      td.className = 'stock-cell ' + (v >= 10 ? 'stock-ok' : v >= 5 ? 'stock-baix' : 'stock-critic');
    } else {
      td.className = 'stock-cell';
    }
  });
}
</script>
