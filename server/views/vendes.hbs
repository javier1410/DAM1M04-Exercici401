<div class="page-header">
  <h1>🛒 Vendes</h1>
</div>

<form class="search-bar" method="GET" action="/vendes">
  <input type="text" name="cerca" value="{{cerca}}" placeholder="Buscar per nom de client..." />
  <button type="submit">🔍 Buscar</button>
  {{#if cerca}}<a href="/vendes" class="btn-secondary">✖ Netejar</a>{{/if}}
</form>

<table class="taula">
  <thead>
    <tr>
      <th>#</th><th>Data</th><th>Client</th><th>Mètode pagament</th><th>Total</th><th>Accions</th>
    </tr>
  </thead>
  <tbody>
    {{#each vendes}}
    <tr>
      <td>#{{id}}</td>
      <td>{{formatDate sale_date}}</td>
      <td>{{client}}</td>
      <td>{{payment_method}}</td>
      <td>{{toFixed2 total}} €</td>
      <td>
        <a href="/vendaDetall?id={{id}}" class="btn-sm">👁 Veure</a>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>

<div class="paginacio">
  {{#if (gt pagina 0)}}
    <a href="/vendes?pagina={{paginaAnterior}}&cerca={{cerca}}" class="btn-secondary">← Anterior</a>
  {{/if}}
  <span>Pàgina {{add pagina 1}} de {{totalPagines}}</span>
  {{#if paginaSeguent}}
    <a href="/vendes?pagina={{paginaSeguent}}&cerca={{cerca}}" class="btn-secondary">Següent →</a>
  {{/if}}
</div>
